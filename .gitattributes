# Normalize line endings to LF in the repo, checkout as OS-native
* text=auto

# Force LF for web/script files
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files
*.tgz binary
*.png binary
*.ico binary
